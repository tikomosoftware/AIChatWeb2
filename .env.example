# ============================================
# Hugging Face API Configuration (必須)
# ============================================
# Hugging Face APIキー（無料枠で利用可能）
# 取得方法: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ============================================
# LLM Model Configuration (オプション)
# ============================================
# 回答生成に使用するLLMモデル
# 推奨: Qwen/Qwen2.5-7B-Instruct (日本語対応・無料枠で利用可能)
# その他の選択肢: meta-llama/Llama-3.1-8B-Instruct, deepseek-ai/DeepSeek-R1
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# ============================================
# LLMプロバイダー切り替え設定 (オプション)
# ============================================
# LLMプロバイダーの選択（huggingface / groq / openrouter）
# 未設定の場合は HUGGINGFACE_API_KEY にフォールバックします
# LLM_PROVIDER=huggingface

# LLMプロバイダー用APIキー（LLM_PROVIDER設定時は必須）
# LLM_API_KEY=your_llm_api_key_here

# 使用するLLMモデル名（未設定時はプロバイダーのデフォルトを使用）
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Hugging Face 設定例 ---
# LLM_PROVIDER=huggingface
# LLM_API_KEY=hf_xxxxx
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Groq 設定例 ---
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_xxxxx
# LLM_MODEL=deepseek-r1-distill-qwen-32b

# --- OpenRouter 設定例 ---
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-xxxxx
# LLM_MODEL=deepseek/deepseek-r1:free

# ============================================
# デバッグ設定 (オプション)
# ============================================
# デバッグモード（true にすると推論ステップがAPIレスポンスに含まれます）
# DEBUG_MODE=false

# ============================================
# Embedding Model Configuration (オプション)
# ============================================
# テキストのベクトル化に使用するモデル
# 推奨: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (多言語対応・384次元)
# その他の選択肢: sentence-transformers/all-MiniLM-L6-v2 (英語特化・軽量)
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# Vector Search Configuration (オプション)
# ============================================
# ベクトル検索で取得する上位K件のドキュメント数
# 推奨値: 3-5
VECTOR_SEARCH_TOP_K=3

# 類似度スコアの閾値（0.0-1.0の範囲）
# この値以下のスコアのドキュメントは除外されます
# 推奨値: 0.3-0.5（paraphrase-multilingual-MiniLM-L12-v2 + 日本語テキストの場合）
# 英語テキストの場合は 0.6-0.8 でも可
VECTOR_SEARCH_THRESHOLD=0.3

# ============================================
# Request Configuration (オプション)
# ============================================
# APIリクエストのタイムアウト時間（ミリ秒）
# Hugging Faceの無料枠では応答に時間がかかる場合があります
# 推奨値: 30000 (30秒)
REQUEST_TIMEOUT=30000

# ============================================
# Supabase Configuration (オプション)
# ============================================
# Supabaseプロジェクト URL
# 取得方法: Supabaseダッシュボード > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase匿名キー（公開可能）
# 取得方法: Supabaseダッシュボード > Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
